#######################################################################################################################################
# REQUIREMENTS to use HdmtOSAlarmBins_CLASS.sbdefs
# 1. File must be imported after Import "<*.bdefs>";
# 2. User *.bdefs file must have 4 levels BinGroup hierarchy - PassFailBins, HardBins, SoftBins and DataBins.
# Any Test Program *.bdefs using 3 levels BinGroup hierarchy, see IMPORTANT NOTES (a)
# 3. The listed Parent-Bins must be defined before importing this file. If there is conflict with existing, see IMPORTANT NOTES (a)
# 4. The defined Alarm Leaf bins in this file must map to the 'Fail' bin under BinGroup PassFailBins
#
# IMPORTANT NOTES:
# a. If ONE or MORE requirements above are NOT MET, Test Program MUST copy-paste ALL DataBins LeafBin Bin-Identifier to *.bdefs file.
# a.1 Must use DataBins Bin-Identifier name AS-IS from this file.
# a.2 User may redefine DataBins, HardBins and/or SoftBins Bin-Number, Bin-Description and Parent-Bin
# b. hdmtOS will fail Test Program load if one or more listed LeafBin Bin-Identifier is missing.
#######################################################################################################################################
Version 1.0;

SubBinDefs
{
    BinGroup HardBins
    {
        Bin b69_FAIL_UNASSIGNED_PORT_ERROR 69: "b69_FAIL_UNASSIGNED_PORT_ERROR", Fail;
        #Bin b88_FAIL_GENERIC_OR_LINUX64_OR_HDMT_DOUBLE_STACK 88 : "b88_FAIL_GENERIC_OR_LINUX64_OR_HDMT_DOUBLE_STACK", Fail;
        Bin b90_FAIL_USER_FUNC 90 : "b90_FAIL_USER_FUNC", Fail;
        Bin b93_FAIL_CL_OR_QA_DOWNBIN_1 93 : "b93_FAIL_CL_OR_QA_DOWNBIN_1", Fail;
        Bin b94_FAIL_CL_OR_QA_DOWNBIN_2 94 : "b94_FAIL_CL_OR_QA_DOWNBIN_2", Fail;
        Bin b95_FAIL_CL_OR_QA_DOWNBIN 95: "b95_FAIL_CL_OR_QA_DOWNBIN", Fail;
        Bin b97_FAIL_UEI_COMMUNICATION_ALARM 97: "b97_FAIL_UEI_COMMUNICATION_ALARM", Fail;
        Bin b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN 98 : "b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN", Fail;
        Bin b99_FAIL_HARDWARE_ERROR 99 : "b99_FAIL_HARDWARE_ERROR", Fail;
        Bin b88_FAIL_CL_OR_QA_DOWNBIN_3 88 : "b88_FAIL_CL_OR_QA_DOWNBIN_3", Fail;
    }
    BinGroup SoftBins
    {
        #HDMTOSALARM Soft BINS
        Bin b6901_FAIL_TESTFLOW_UNASSIGNED_PORT_ERROR 6901:"b6901_FAIL_TESTFLOW_UNASSIGNED_PORT_ERROR",b69_FAIL_UNASSIGNED_PORT_ERROR;
        Bin b9531_FAIL_UNCORRECTABLE_ECC_ERROR 9531: "b9531_FAIL_UNCORRECTABLE_ECC_ERROR", b95_FAIL_CL_OR_QA_DOWNBIN;
        Bin b9561_FAIL_DUT_TEMPERATURE_LIMIT_ALARM 9561: "b9561_FAIL_DUT_TEMPERATURE_LIMIT_ALARM", b95_FAIL_CL_OR_QA_DOWNBIN;
        Bin b8862_FAIL_DUT_POWER_LIMIT_ALARM 8862: "b8862_FAIL_DUT_POWER_LIMIT_ALARM", b88_FAIL_CL_OR_QA_DOWNBIN_3;
        Bin b9769_FAIL_UEI_COMMUNICATION_ALARM 9769: "b9769_FAIL_UEI_COMMUNICATION_ALARM", b97_FAIL_UEI_COMMUNICATION_ALARM;
        Bin b9801_FAIL_TESTCLASS_EXCEPTION_ERROR 9801:"b9801_FAIL_TESTCLASS_EXCEPTION_ERROR", b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        Bin b9802_FAIL_TESTFLOW_CALLBACK_ERROR 9802: "b9802_FAIL_TESTFLOW_CALLBACK_ERROR",b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        Bin b9803_FAIL_TESTFLOW_MTT_ERROR 9803: "b9803_FAIL_TESTFLOW_MTT_ERROR", b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        Bin b9804_FAIL_TESTFLOW_FLOWITEMRESULT_ERROR 9804: "b9804_FAIL_TESTFLOW_FLOWITEMRESULT_ERROR", b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        Bin b9870_FAIL_TESTFLOW_DUTSYNC_ALARM 9870: "b9870_FAIL_TESTFLOW_DUTSYNC_ALARM", b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        Bin b9899_FAIL_HALT_ALARM 9899: "b9899_FAIL_HALT_ALARM", b98_FAIL_SOFTWARE_ALARM_OR_ZERO_BIN;
        #Bin b9901_fail_FAIL_DPS_ALARM 9901 : "b9901_fail_FAIL_DPS_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9968_FAIL_DPS_OVERVOLTAGE_ALARM 9968: "b9968_FAIL_DPS_OVERVOLTAGE_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9969_FAIL_DPS_CORRUPTION_ALARM 9969: "b9969_FAIL_DPS_CORRUPTION_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9971_FAIL_BULKPOWERSUPPLY_POWERLIMIT_ALARM 9971: "b9971_FAIL_BULKPOWERSUPPLY_POWERLIMIT_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9972_FAIL_HBICC_CYCLESLIP_ALARM 9972: "b9972_FAIL_HBICC_CYCLESLIP_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9973_FAIL_HBICC_OCTCALHANDSHAKE_ALARM 9973: "b9973_FAIL_HBICC_OCTCALHANDSHAKE_ALARM", b99_FAIL_HARDWARE_ERROR;
        Bin b9974_FAIL_HBICC_OCTZEROCAL_ALARM 9974: "b9974_FAIL_HBICC_OCTZEROCAL_ALARM",b99_FAIL_HARDWARE_ERROR;
        Bin b9975_FAIL_AURORALINK_COMMUNICATION_ALARM 9975: "b9975_FAIL_AURORALINK_COMMUNICATION_ALARM",b99_FAIL_HARDWARE_ERROR;
    }
    BinGroup DataBins
    {
        # BinType Bin-Identifier Bin-Number : Bin-Description Parent-Bin
        LeafBin FAIL_TESTFLOW_UNASSIGNED_PORT_ERROR 90696901 : "FAIL_TESTFLOW_UNASSIGNED_PORT_ERROR", b6901_FAIL_TESTFLOW_UNASSIGNED_PORT_ERROR;
        LeafBin FAIL_UNCORRECTABLE_ECC_ERROR 90959531 : "FAIL_UNCORRECTABLE_ECC_ERROR", b9531_FAIL_UNCORRECTABLE_ECC_ERROR;
