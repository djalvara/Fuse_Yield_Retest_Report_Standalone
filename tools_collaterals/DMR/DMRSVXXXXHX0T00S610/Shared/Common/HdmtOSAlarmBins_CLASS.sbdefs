        LeafBin FAIL_UEI_COMMUNICATION_ALARM 90979769 : "FAIL_UEI_COMMUNICATION_ALARM", b9769_FAIL_UEI_COMMUNICATION_ALARM;
        LeafBin FAIL_TESTCLASS_EXCEPTION_ERROR 90989801 : "FAIL_TESTCLASS_EXCEPTION_ERROR", b9801_FAIL_TESTCLASS_EXCEPTION_ERROR;
        LeafBin FAIL_TESTFLOW_CALLBACK_ERROR 90989802 : "FAIL_TESTFLOW_CALLBACK_ERROR", b9802_FAIL_TESTFLOW_CALLBACK_ERROR;
        LeafBin FAIL_TESTFLOW_MTT_ERROR 90989803 : "FAIL_TESTFLOW_MTT_ERROR", b9803_FAIL_TESTFLOW_MTT_ERROR;
        LeafBin FAIL_TESTFLOW_FLOWITEMRESULT_ERROR 90989804 : "FAIL_TESTFLOW_FLOWITEMRESULT_ERROR", b9804_FAIL_TESTFLOW_FLOWITEMRESULT_ERROR;
        LeafBin FAIL_TESTFLOW_DUTSYNC_ALARM 90989870 : "FAIL_TESTFLOW_DUTSYNC_ALARM", b9870_FAIL_TESTFLOW_DUTSYNC_ALARM;
        LeafBin FAIL_HALT_ALARM 90989899 : "FAIL_HALT_ALARM", b9899_FAIL_HALT_ALARM;
        LeafBin FAIL_DPS_OVERVOLTAGE_ALARM 90999968 : "FAIL_DPS_OVERVOLTAGE_ALARM", b9968_FAIL_DPS_OVERVOLTAGE_ALARM;
        LeafBin FAIL_DPS_CORRUPTION_ALARM 90999969 : "FAIL_DPS_CORRUPTION_ALARM", b9969_FAIL_DPS_CORRUPTION_ALARM;
        LeafBin FAIL_BULKPOWERSUPPLY_POWERLIMIT_ALARM 90999971 : "FAIL_BULKPOWERSUPPLY_POWERLIMIT_ALARM", b9971_FAIL_BULKPOWERSUPPLY_POWERLIMIT_ALARM;
        LeafBin FAIL_HBICC_CYCLESLIP_ALARM 90999972 : "FAIL_HBICC_CYCLESLIP_ALARM", b9972_FAIL_HBICC_CYCLESLIP_ALARM;
        LeafBin FAIL_HBICC_OCTCALHANDSHAKE_ALARM 90999973 : "FAIL_HBICC_OCTCALHANDSHAKE_ALARM", b9973_FAIL_HBICC_OCTCALHANDSHAKE_ALARM;
        LeafBin FAIL_HBICC_OCTZEROCAL_ALARM 90999974 : "FAIL_HBICC_OCTZEROCAL_ALARM", b9974_FAIL_HBICC_OCTZEROCAL_ALARM;
        LeafBin FAIL_AURORALINK_COMMUNICATION_ALARM 90999975 : "FAIL_AURORALINK_COMMUNICATION_ALARM", b9975_FAIL_AURORALINK_COMMUNICATION_ALARM;
        LeafBin FAIL_DUT_POWER_LIMIT_ALARM 90998862 : "FAIL_DUT_POWER_LIMIT_ALARM", b8862_FAIL_DUT_POWER_LIMIT_ALARM;
    }
}